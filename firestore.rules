rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Profile Validation
    function isValidUserProfile(data) {
      return data.keys().hasAll(['displayName', 'email', 'createdAt'])
        && data.displayName is string && data.displayName.size() <= 100
        && data.email is string && data.email.size() <= 200
        && data.createdAt is timestamp
        && (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    // Task Validation
    function isValidTask(data, userId) {
      return data.keys().hasAll(['title', 'startTime', 'endTime', 'categoryId', 'recurrence', 'userId'])
        && data.title is string && data.title.size() <= 200
        && data.startTime is timestamp
        && data.endTime is timestamp
        && data.categoryId is string && data.categoryId.size() <= 100
        && data.recurrence in ['none', 'daily', 'weekdays', 'weekends', 'weekly', 'monthly']
        && data.userId == userId
        && (!('color' in data) || (data.color is string && data.color.size() <= 20))
        && (!('icon' in data) || (data.icon is string && data.icon.size() <= 50))
        && (!('description' in data) || (data.description is string && data.description.size() <= 1000))
        && (!('updatedAt' in data) || data.updatedAt is timestamp)
        && (!('createdAt' in data) || data.createdAt is timestamp);
    }

    // Category Validation
    function isValidCategory(data, userId) {
      return data.keys().hasAll(['name', 'color', 'userId'])
        && data.name is string && data.name.size() <= 50
        && data.color is string && data.color.size() <= 20
        && data.userId == userId;
    }

    // Rules
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserProfile(incoming());
      allow update: if isOwner(userId) && isValidUserProfile(incoming()) 
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'email', 'updatedAt', 'createdAt']);

      match /tasks/{taskId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidTask(incoming(), userId) && isValidId(taskId);
        allow update: if isOwner(userId) && isValidTask(incoming(), userId)
          && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'color', 'icon', 'startTime', 'endTime', 'categoryId', 'recurrence', 'reminderSent', 'updatedAt', 'createdAt']);
        allow delete: if isOwner(userId);
      }

      match /categories/{categoryId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidCategory(incoming(), userId) && isValidId(categoryId);
        allow update: if isOwner(userId) && isValidCategory(incoming(), userId)
          && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'color']);
        allow delete: if isOwner(userId);
      }
    }
  }
}
