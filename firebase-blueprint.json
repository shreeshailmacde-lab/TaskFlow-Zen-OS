{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user basic information and preferences",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["displayName", "email", "createdAt"]
    },
    "Task": {
      "title": "Task",
      "description": "A scheduled task or event",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "color": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "categoryId": { "type": "string" },
        "recurrence": { "type": "string", "enum": ["none", "daily", "weekdays", "weekends", "weekly", "monthly"] },
        "reminderSent": { "type": "boolean" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "startTime", "endTime", "categoryId", "recurrence", "userId"]
    },
    "Category": {
      "title": "Category",
      "description": "A task classification",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "color": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "color", "userId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile data"
    },
    "/users/{userId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "User-specific tasks"
    },
    "/users/{userId}/categories/{categoryId}": {
      "schema": "Category",
      "description": "User-specific categories"
    }
  }
}
